#!/bin/bash
# Omarchy Glass - post-update hook
# Re-applies visual customizations if overwritten by omarchy-update

GLASS_DIR="@@GLASS_DIR@@"
if [ "$GLASS_DIR" = "@@GLASS_DIR@@" ] || [ ! -d "$GLASS_DIR" ]; then
    GLASS_DIR="$HOME/.local/share/omarchy-glass"
fi

RESTORED=()

# Restore target from source when changed or missing.
restore_if_changed() {
    local source="$1"
    local target="$2"
    local label="$3"

    [ -f "$source" ] || return 0
    mkdir -p "$(dirname "$target")"

    if [ ! -f "$target" ] || ! diff -q "$source" "$target" > /dev/null 2>&1; then
        if [ -f "$target" ]; then
            cp "$target" "$target.pre-glass.$(date +%s)"
        fi
        cp "$source" "$target"
        RESTORED+=("$label")
    fi
}

# Check key config files
restore_if_changed \
    "$GLASS_DIR/configs/hypr/looknfeel.conf" \
    "$HOME/.config/hypr/looknfeel.conf" \
    "Hyprland"

# Keep border gradient synced with current theme when possible.
if [ -x "$GLASS_DIR/lib/update-border-gradient.sh" ]; then
    "$GLASS_DIR/lib/update-border-gradient.sh"
fi

# For mako, just ensure our tweaks survive
MAKO_CONF="$HOME/.config/mako/config"
if [ -f "$MAKO_CONF" ]; then
    changed=false
    if ! grep -q 'border-radius' "$MAKO_CONF"; then
        echo "border-radius=12" >> "$MAKO_CONF"
        changed=true
    fi
    if grep -q '^background-color=#[0-9a-fA-F]\{6\}$' "$MAKO_CONF"; then
        sed -i 's/^background-color=#\([0-9a-fA-F]\{6\}\)$/background-color=#\1BF/' "$MAKO_CONF"
        changed=true
    fi
    if $changed; then
        RESTORED+=("Mako")
    fi
fi

# Ensure waybar active workspace icon + clock format
WAYBAR_CONF="$HOME/.config/waybar/config.jsonc"
if [ -f "$WAYBAR_CONF" ]; then
    changed=false
    if grep -q '"active": "󱓻"' "$WAYBAR_CONF"; then
        sed -i 's/"active": "󱓻"/"active": "●"/' "$WAYBAR_CONF"
        changed=true
    fi
    if grep -q '"format": "{:L%A %H:%M}"' "$WAYBAR_CONF"; then
        sed -i 's/"format": "{:L%A %H:%M}"/"format": "{:L%A · %H:%M:%S}",\n    "interval": 1/' "$WAYBAR_CONF"
        changed=true
    fi
    $changed && RESTORED+=("Waybar config")
fi

# Ensure alacritty opacity
ALACRITTY_CONF="$HOME/.config/alacritty/alacritty.toml"
if [ -f "$ALACRITTY_CONF" ] && ! grep -q 'opacity' "$ALACRITTY_CONF"; then
    sed -i '/^decorations/a opacity = 0.92' "$ALACRITTY_CONF"
    RESTORED+=("Alacritty")
fi

# Ensure SwayOSD glass
SWAYOSD_CSS="$HOME/.config/swayosd/style.css"
if [ -f "$SWAYOSD_CSS" ]; then
    changed=false
    if grep -q 'border-radius: 0;' "$SWAYOSD_CSS"; then
        sed -i '/progressbar {/{n;s/border-radius: 0;/border-radius: 6px;/}' "$SWAYOSD_CSS"
        sed -i 's/border-radius: 0;/border-radius: 12px;/' "$SWAYOSD_CSS"
        changed=true
    fi
    if grep -q 'opacity: 0.97;' "$SWAYOSD_CSS"; then
        sed -i 's/opacity: 0.97;/opacity: 0.85;/' "$SWAYOSD_CSS"
        changed=true
    fi
    if $changed; then
        RESTORED+=("SwayOSD")
    fi
fi

# Ensure btop transparency
BTOP_CONF="$HOME/.config/btop/btop.conf"
if [ -f "$BTOP_CONF" ] && grep -q '^theme_background = True' "$BTOP_CONF"; then
    sed -i 's/^theme_background = True/theme_background = False/' "$BTOP_CONF"
    RESTORED+=("btop")
fi

# Restart services if anything was restored
if [ ${#RESTORED[@]} -gt 0 ]; then
    list=$(printf ', %s' "${RESTORED[@]}")
    list=${list:2}
    hyprctl reload 2>/dev/null || true
    omarchy-restart-waybar 2>/dev/null || true
    omarchy-restart-walker 2>/dev/null || true
    makoctl reload 2>/dev/null || true
    notify-send "Omarchy Glass" "Restored visual tweaks after update: ${list}" 2>/dev/null || true
fi
